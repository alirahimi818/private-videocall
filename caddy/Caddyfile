# EDGE_DOMAIN is an optional second hostname (e.g. a domain proxied through
# Cloudflare's CDN, orange-cloud) serving the exact same app — a fallback
# ingress path for networks that block/throttle the primary DOMAIN directly.
# Caddy manages a separate cert for it automatically. Leave EDGE_DOMAIN unset
# to run with just DOMAIN.
{$DOMAIN} {$EDGE_DOMAIN} {
	encode gzip

	# Caddy reorders directives by a fixed internal priority regardless of
	# file order (try_files would otherwise run before reverse_proxy and
	# swallow /api and /ws into index.html). route{} forces literal,
	# sequential evaluation instead.
	route /api/* {
		reverse_proxy node-service:8080
	}

	route /ws* {
		reverse_proxy node-service:8080
	}

	route {
		root * /srv

		# Vite content-hashes /assets/* filenames, so those are safe to cache
		# hard. Everything else (index.html, and every SPA route that falls
		# back to it via try_files below, e.g. / and /call/*) must always be
		# revalidated, or a stale shell can keep pointing at a bundle that no
		# longer exists / no longer has a given fix.
		header Cache-Control "no-cache"
		@immutable path /assets/*
		header @immutable Cache-Control "public, max-age=31536000, immutable"

		try_files {path} /index.html
		file_server
	}
}
