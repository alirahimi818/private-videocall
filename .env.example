# Public domain for the SPA + signaling, served by Caddy on the primary IP.
# Caddy requests/renews its Let's Encrypt cert for this automatically.
DOMAIN=call.example.com

# The primary IP itself. Caddy's ports are bound explicitly to this IP so
# it doesn't also grab :443 on the second IP, which coturn needs for TLS.
PRIMARY_IP=203.0.113.1

# Public hostname for TURN over TLS (turns:), served by coturn on the
# SECOND dedicated IP. Must have its own DNS A record pointing at that IP.
TURN_DOMAIN=turn.example.com

# The second IP address itself. Required because Caddy already owns
# 443/tcp on the primary IP; coturn's tls-listening-port=443 needs a
# separate IP to bind to.
TURN_SECOND_IP=203.0.113.10

# TURN realm, typically the same as TURN_DOMAIN.
TURN_REALM=turn.example.com

# Shared secret for coturn's use-auth-secret REST API mechanism.
# Generate with: openssl rand -hex 32
# Must be identical between coturn and node-service.
TURN_SHARED_SECRET=change-me-to-a-long-random-value

# UDP relay port range opened in the firewall for coturn (host networking).
# A small range is enough for 1-2 concurrent calls.
TURN_MIN_PORT=49160
TURN_MAX_PORT=49200
